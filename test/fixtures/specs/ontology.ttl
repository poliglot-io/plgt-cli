@prefix ex: <http://example.org/matrix/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .


# Matrix Ontology Definition

ex:Matrix
    rdf:type owl:Class ;
    rdfs:label "Matrix" ;
    rdfs:comment "A computational matrix for data processing" .

ex:hasVersion
    rdf:type owl:DatatypeProperty ;
    rdfs:domain ex:Matrix ;
    rdfs:range rdfs:Literal ;
    rdfs:label "has version" .

ex:hasSpecification
    rdf:type owl:ObjectProperty ;
    rdfs:domain ex:Matrix ;
    rdfs:range ex:Specification ;
    rdfs:label "has specification" .

ex:Specification
    rdf:type owl:Class ;
    rdfs:label "Specification" ;
    rdfs:comment "A specification document for a matrix" .
