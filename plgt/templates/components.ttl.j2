@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix plgt-ui: <https://poliglot.io/os/spec/ui#> .
@prefix plgt-build: <https://poliglot.io/os/spec/build#> .
@prefix plgt-cnt: <https://poliglot.io/os/spec/content#> .
@prefix : <{{ matrix_uri }}> .

# Auto-generated by plgt build - do not edit manually

# Bundle - the compiled JS artifact
:components a plgt-ui:Bundle ;
    rdfs:isDefinedBy : ;
    plgt-build:path "components.js" ;
    plgt-cnt:format plgt-cnt:ApplicationJavascript .
{% for export in exports %}

# Component: {{ export }}
:{{ export }}Component a plgt-ui:Component ;
    plgt-ui:bundle :components ;
    plgt-ui:exportName "{{ export }}" .
{% endfor %}
