{
  "_comment": "Shared parity fixtures for the engine version range evaluator. The authoritative server-side evaluator and the CLI's Python implementation (plgt/utils/version_range.py) MUST produce identical results for every case in this file. Update this file in lockstep with both implementations.",
  "satisfies_range": [
    {
      "workspace": "2.1.5",
      "range": ">=2.1 <3.0",
      "expected": true,
      "comment": "workspace minor 2.1 within [2.1, 3.0)"
    },
    {
      "workspace": "2.1.0",
      "range": ">=2.1 <3.0",
      "expected": true,
      "comment": "workspace exactly at floor minor"
    },
    {
      "workspace": "2.0.7",
      "range": ">=2.1 <4",
      "expected": false,
      "comment": "workspace minor 2.0 below floor 2.1"
    },
    {
      "workspace": "3.0.0",
      "range": ">=2 <3",
      "expected": false,
      "comment": "workspace minor 3.0 at exclusive ceiling 3.0"
    },
    {
      "workspace": "2.9.99",
      "range": ">=2 <3",
      "expected": true,
      "comment": "workspace minor 2.9 just below ceiling 3.0; patch ignored"
    },
    {
      "workspace": "3.1.5",
      "range": ">=2 <4",
      "expected": true,
      "comment": "workspace minor 3.1 within [2.0, 4.0)"
    },
    {
      "workspace": "1.9.0",
      "range": ">=2 <4",
      "expected": false,
      "comment": "workspace minor 1.9 below floor 2.0"
    },
    {
      "workspace": "4.0.0",
      "range": ">=2 <4",
      "expected": false,
      "comment": "workspace minor 4.0 at exclusive ceiling 4.0"
    },
    {
      "workspace": "2.0.0",
      "range": ">=2",
      "expected": true,
      "comment": "single-bound floor; bare major treated as 2.0"
    },
    {
      "workspace": "1.99.99",
      "range": ">=2",
      "expected": false,
      "comment": "single-bound floor blocks workspace minor 1.99"
    },
    {
      "workspace": "100.50.0",
      "range": ">=2",
      "expected": true,
      "comment": "single-bound floor with no ceiling permits arbitrarily high"
    },
    {
      "workspace": "2.5.3",
      "range": "<3",
      "expected": true,
      "comment": "single-bound ceiling; bare major treated as 3.0"
    },
    {
      "workspace": "3.0.0",
      "range": "<3",
      "expected": false,
      "comment": "single-bound exclusive ceiling at 3.0"
    },
    {
      "workspace": "3.0.0",
      "range": "<3.0",
      "expected": false,
      "comment": "<3 and <3.0 evaluate identically"
    },
    {
      "workspace": "2.1.4",
      "range": ">=2.1 <3",
      "expected": true,
      "comment": "exact minor match; mixed major and major.minor bounds"
    },
    {
      "workspace": "2.0.0",
      "range": ">=2.0 <2.1",
      "expected": true,
      "comment": "narrow single-minor band, lower edge"
    },
    {
      "workspace": "2.1.0",
      "range": ">=2.0 <2.1",
      "expected": false,
      "comment": "narrow single-minor band, upper edge excluded"
    },
    {
      "workspace": "0.1.0",
      "range": ">=0 <1",
      "expected": true,
      "comment": "0.x range; workspace within"
    },
    {
      "workspace": "0.1.0",
      "range": ">=0.2 <1",
      "expected": false,
      "comment": "0.x range; workspace below floor"
    },
    {
      "workspace": "10.20.30",
      "range": ">=10.20 <11",
      "expected": true,
      "comment": "multi-digit components"
    }
  ],
  "validate_range_valid": [
    ">=2",
    ">=2.1",
    "<3",
    "<3.0",
    ">=2.1 <3.0",
    "<3 >=2",
    ">=2 <4",
    ">=0 <1",
    ">=10.20 <11"
  ],
  "validate_range_invalid": [
    {
      "input": ">=2.1.3",
      "reason": "patch component"
    },
    {
      "input": ">=2 <2.1.5",
      "reason": "patch component in second bound"
    },
    {
      "input": ">2.1",
      "reason": "unsupported operator >"
    },
    {
      "input": "<=3.0",
      "reason": "unsupported operator <="
    },
    {
      "input": "=2.1",
      "reason": "unsupported operator ="
    },
    {
      "input": "~2.1",
      "reason": "unsupported operator ~"
    },
    {
      "input": "^2.1",
      "reason": "unsupported operator ^"
    },
    {
      "input": "",
      "reason": "empty string"
    },
    {
      "input": "   ",
      "reason": "whitespace-only string"
    },
    {
      "input": ">=",
      "reason": "operator with no version"
    },
    {
      "input": "2.1",
      "reason": "version with no operator"
    },
    {
      "input": ">=2.1 <3.0 <4.0",
      "reason": "more than two bounds"
    },
    {
      "input": ">=abc",
      "reason": "non-numeric component"
    },
    {
      "input": ">=2.1.",
      "reason": "trailing dot"
    },
    {
      "input": ">=2..1",
      "reason": "empty component"
    },
    {
      "input": ">=2 >=3",
      "reason": "two same-op bounds (both lower)"
    },
    {
      "input": "<3 <5",
      "reason": "two same-op bounds (both upper)"
    },
    {
      "input": ">=3 <3",
      "reason": "empty interval at touching boundary"
    },
    {
      "input": ">=5 <3",
      "reason": "inverted bounds (lower above upper)"
    },
    {
      "input": ">=2.5 <2.3",
      "reason": "inverted bounds on minor"
    }
  ]
}
